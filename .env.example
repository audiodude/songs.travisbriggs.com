# Cloudflare R2 (S3 API) — used by `pnpm add-song` to upload mp3s.
# Create an R2 API token in the Cloudflare dashboard (Object Read & Write),
# scoped to the audio bucket. NEVER commit the real .env (it is gitignored).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=songs-travisbriggs-audio

# Public site config (read by Astro at build; safe to expose).
PUBLIC_AUDIO_BASE=https://audio.songs.travisbriggs.com
PUBLIC_MATOMO_SITE_ID=
