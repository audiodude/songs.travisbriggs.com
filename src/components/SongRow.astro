---
import type { Song } from '../lib/types';
import { fmtMonthYear, fmtDuration } from '../lib/format';

interface Props {
  song: Song;
  /** when set, render the related-row variant showing these shared tags */
  shared?: string[];
}

const { song, shared } = Astro.props;
const related = shared !== undefined;
const chips = related ? shared! : song.tags;
const titleSize = related ? 26 : 33;
const tagsWidth = related ? 200 : 230;
// Chips are 19px tall + 5px gap, so 2 lines = 43px; clip just past that so a
// third line never peeks through. Related rows show a single line.
const tagsMaxH = related ? 20 : 44;
const tagsAttr = song.tags.join(',');
---

<div
  class="song-row"
  data-play
  data-slug={song.slug}
  data-title={song.title}
  data-src={song.src}
  data-tags={tagsAttr}
  style="display:flex; align-items:center; gap:20px; padding:16px 0; border-bottom:1px solid var(--border); cursor:pointer;"
>
  <button type="button" class="note" aria-label={`Play ${song.title}`}>
    <span class="note-music">♪</span>
    <span class="note-play" aria-hidden="true"></span>
  </button>

  <span
    class="row-title"
    style={`flex:1; min-width:0; font-family:var(--font-display); font-weight:700; font-size:${titleSize}px; line-height:1; letter-spacing:-.02em; color:var(--text); overflow:hidden; text-overflow:ellipsis; white-space:nowrap;`}
  >{song.title}</span>

  <span class="row-tags" style={`display:flex; flex-wrap:wrap; justify-content:flex-end; align-content:flex-start; gap:5px; flex:0 0 auto; width:${tagsWidth}px; max-height:${tagsMaxH}px; overflow:hidden;`}>
    {
      chips.map((t) =>
        related ? (
          <span style="font:400 11px/1 var(--font-mono); color:var(--chip-text); background:var(--rest); padding:4px 8px; border-radius:var(--radius-chip); white-space:nowrap;">{t}</span>
        ) : (
          <a href={`/?tag=${encodeURIComponent(t)}`} data-tag={t} class="chip" style="font:400 11px/1 var(--font-mono); color:var(--chip-text); background:var(--rest); padding:4px 8px; border-radius:var(--radius-chip); white-space:nowrap; text-decoration:none; transition:color .15s, background .15s;">{t}</a>
        ),
      )
    }
  </span>

  <span class="row-date" style="font:400 12px/1 var(--font-mono); color:var(--faint); flex:0 0 auto; width:74px; text-align:right;">{fmtMonthYear(song.date)}</span>
  <span style="font:400 12px/1 var(--font-mono); color:var(--accent); flex:0 0 auto; width:38px; text-align:right;">{fmtDuration(song.duration)}</span>

  <a class="inspect" href={`/${song.slug}/`} aria-label={`Open ${song.title}`}>›</a>
</div>

<style>
  .song-row:hover {
    --note: var(--accent);
    background: var(--row-wash);
  }

  /* note: ♪ at rest, play triangle on row hover (decorative — the whole row plays) */
  .note {
    flex: 0 0 auto;
    width: 36px;
    height: 36px;
    padding: 0;
    border: none;
    background: none;
    -webkit-appearance: none;
    appearance: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--note, #fff);
    transition: color 0.15s;
  }
  .note-music { font-size: 30px; line-height: 1; }
  .note-play {
    display: none;
    width: 0;
    height: 0;
    border-left: 17px solid currentColor;
    border-top: 11px solid transparent;
    border-bottom: 11px solid transparent;
    margin-left: 4px;
  }
  .song-row:hover .note-music { display: none; }
  .song-row:hover .note-play { display: inline-block; }

  .chip:hover {
    background: var(--accent) !important;
    color: #fff !important;
  }

  /* inspect: open the song's page */
  /* inspect: a big bare chevron that opens the song's page */
  .inspect {
    flex: 0 0 auto;
    width: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--faint);
    text-decoration: none;
    font: 400 44px/1 var(--font-body);
    transition: color 0.15s, transform 0.15s;
  }
  .song-row:hover .inspect { color: var(--accent-light); }
  .inspect:hover { color: var(--accent); transform: translateX(2px); }
</style>
