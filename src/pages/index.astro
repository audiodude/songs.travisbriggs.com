---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import SongRow from '../components/SongRow.astro';
import Controls from '../components/Controls.tsx';
import { loadVisibleSongs, tagIndex } from '../lib/songs';

const songs = await loadVisibleSongs();
const { tags, freq } = tagIndex(songs);
---

<Base description="Personal song catalog by Travis Briggs — demos, jokes, heartbreakers.">
  <div
    style="max-width:var(--maxw); margin:40px auto; background:var(--card); border-radius:var(--radius-card); box-shadow:0 16px 50px rgba(0,0,0,.4); overflow:hidden;"
  >
    <Hero />

    <div style="padding:16px 44px; border-top:1px solid var(--border); border-bottom:1px solid var(--border);">
      <Controls client:load tags={tags} freq={freq} total={songs.length} />
    </div>

    <ul data-song-list style="list-style:none; margin:0; padding:6px 44px 96px;">
      {
        songs.map((s) => (
          <li id={s.slug} class="song">
            <SongRow song={s} />
          </li>
        ))
      }
      <li
        data-empty
        style="display:none; padding:48px 0; text-align:center; font:400 15px/1.6 var(--font-body); color:var(--muted);"
      >
        No songs match that combination. Even your taste isn't <em>that</em> specific. Try fewer tags.
      </li>
    </ul>
  </div>

  <script>
    import '../scripts/wire-play.ts';
  </script>
</Base>
