# Cloudflare R2 upload for `pnpm add-song` — it shells out to wrangler, which uses
# your Cloudflare API token. The token comes from your shell (~/.secrets exports
# CF_API_TOKEN); you only need the non-secret values below. Copy this to .env.
R2_BUCKET=songs-travisbriggs-audio
CLOUDFLARE_ACCOUNT_ID=059181f68081f9c0fb55c5c77a969c11

# Public site config (read by Astro at build; safe to expose).
PUBLIC_AUDIO_BASE=https://audio.songs.travisbriggs.com
# Matomo site id defaults to 5 in production builds; override here only if needed.
PUBLIC_MATOMO_SITE_ID=
