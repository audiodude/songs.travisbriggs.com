---
import { marked } from 'marked';
import Base from '../layouts/Base.astro';
import SongRow from '../components/SongRow.astro';
import DetailPlayer from '../components/DetailPlayer.tsx';
import { loadSongs, relatedByTag, neighbors } from '../lib/songs';
import { fmtLongDate, fmtDuration } from '../lib/format';
import { SOCIAL } from '../lib/site';

export async function getStaticPaths() {
  const all = await loadSongs();
  const visible = all.filter((s) => !s.hidden);
  return all.map((song) => ({
    params: { slug: song.slug },
    props: { song, related: relatedByTag(song, all), nb: neighbors(song, visible) },
  }));
}

const { song, related, nb } = Astro.props;
const noteHtml = song.note ? await marked.parse(song.note) : null;
const track = { slug: song.slug, title: song.title, src: song.src, tags: song.tags };
const externals = [
  { label: 'travisbriggs.com ↗', href: SOCIAL.site },
  { label: 'Mastodon ↗', href: SOCIAL.mastodon },
  { label: 'GitHub ↗', href: SOCIAL.github },
];
---

<Base title={song.title} description={song.note?.slice(0, 160) || `A song by Travis Briggs.`}>
  <div
    class="card"
    style="max-width:var(--maxw); margin:40px auto 140px; background:var(--card); border-radius:var(--radius-card); box-shadow:0 16px 50px rgba(0,0,0,.4); overflow:hidden;"
  >
    <!-- top bar -->
    <div class="detail-topnav" style="display:flex; align-items:center; padding:22px var(--pad); border-bottom:1px solid var(--border);">
      <a href="/" class="nav-link" style="display:inline-flex; align-items:center; gap:8px; font:600 15px/1 var(--font-body); color:var(--muted); text-decoration:none;">
        <span style="font-size:15px; line-height:1;">←</span> All Songs
      </a>
      <div style="flex:1;"></div>
      <nav style="display:flex; align-items:center; flex-wrap:wrap; gap:14px 22px;">
        {externals.map((l) => (
          <a href={l.href} target="_blank" rel="noopener" class="nav-link" style="font:600 15px/1 var(--font-body); color:var(--muted); text-decoration:none;">{l.label}</a>
        ))}
      </nav>
    </div>

    <!-- now playing -->
    <div style="padding:44px var(--pad) 38px; background:var(--hero-wash);">
      <div style="display:flex; align-items:center; gap:9px; margin-bottom:20px;">
        <span style="width:8px; height:8px; border-radius:50%; background:var(--accent); animation:pulseDot 1.8s ease-in-out infinite;"></span>
        <span style="font:700 11px/1 var(--font-mono); color:var(--accent); letter-spacing:.22em; text-transform:uppercase;">Now Playing</span>
      </div>
      <h1 class="detail-title" style="margin:0; font-family:var(--font-display); font-weight:800; line-height:.92; letter-spacing:-.03em; max-width:760px;">{song.title}</h1>

      <div style="display:flex; align-items:center; gap:14px; margin-top:18px; flex-wrap:wrap;">
        <span style="font:400 13px/1 var(--font-mono); color:var(--muted);">{fmtLongDate(song.date)}</span>
        <span style="width:3px; height:3px; border-radius:50%; background:var(--border-strong);"></span>
        <span style="font:400 13px/1 var(--font-mono); color:var(--muted);">{fmtDuration(song.duration)}</span>
        {song.tags.length > 0 && <span style="width:3px; height:3px; border-radius:50%; background:var(--border-strong);"></span>}
        <span style="display:flex; flex-wrap:wrap; gap:6px;">
          {song.tags.map((t) => (
            <a href={`/?tag=${encodeURIComponent(t)}`} data-tag={t} class="meta-chip" style="font:400 11px/1 var(--font-mono); color:var(--chip-text); background:var(--rest); padding:4px 8px; border-radius:var(--radius-chip); white-space:nowrap; text-decoration:none; transition:color .15s,background .15s;">{t}</a>
          ))}
        </span>
      </div>

      <DetailPlayer client:load track={track} durationMs={song.duration} />

      <div style="display:flex; align-items:center; gap:12px; margin-top:30px; flex-wrap:wrap;">
        <a href={song.src} download class="dl-btn" style="display:inline-flex; align-items:center; gap:8px; padding:11px 20px; border-radius:999px; font:600 13px/1 var(--font-body); color:#fff; text-decoration:none; background:var(--accent); transition:background .15s;">↓ Download MP3</a>
        <button type="button" data-copy-link class="copy-btn" style="display:inline-flex; align-items:center; gap:8px; padding:11px 18px; border-radius:999px; font:600 13px/1 var(--font-body); color:var(--accent-light); background:transparent; border:1px solid var(--accent); cursor:pointer; transition:color .15s,border-color .15s;">⧉ Copy link</button>
        <span style="margin-left:auto; font:400 11px/1 var(--font-mono); color:var(--faint); letter-spacing:.06em;">CC BY-SA 4.0</span>
      </div>
    </div>

    <!-- note -->
    <div style="padding:6px var(--pad) 8px;">
      <div style="font:700 11px/1 var(--font-mono); color:var(--faint); letter-spacing:.18em; text-transform:uppercase; margin-bottom:14px;">— About this one</div>
      {noteHtml ? (
        <div class="note-body" set:html={noteHtml}></div>
      ) : (
        <p style="margin:0; font-size:17px; line-height:1.7; color:var(--chip-text); max-width:62ch;">No note on this one — it speaks for itself. Or it doesn't. Press play and decide.</p>
      )}
    </div>

    <!-- related -->
    {related.length > 0 && (
      <div style="padding:34px var(--pad) 6px;">
        <div style="font:700 11px/1 var(--font-mono); color:var(--faint); letter-spacing:.18em; text-transform:uppercase; margin-bottom:6px;">— More like this</div>
        <div>
          {related.map((r) => <SongRow song={r.song} shared={r.shared} />)}
        </div>
      </div>
    )}

    <!-- prev / next -->
    {(nb.older || nb.newer) && (
      <div class="prevnext" style="display:grid; grid-template-columns:1fr 1fr; gap:14px; padding:30px var(--pad) 40px;">
        {nb.older ? (
          <a href={`/${nb.older.slug}/`} class="pn-card" style="display:flex; align-items:center; gap:14px; background:#1b232f; border:1px solid var(--border); border-radius:8px; padding:16px 18px; text-decoration:none; transition:border-color .15s;">
            <span style="width:34px; height:34px; flex:0 0 34px; border-radius:50%; border:1px solid var(--border-strong); display:flex; align-items:center; justify-content:center; color:var(--chip-text); font-size:13px;">←</span>
            <span style="min-width:0;">
              <span style="display:block; font:700 10px/1 var(--font-mono); color:var(--faint); letter-spacing:.12em; text-transform:uppercase;">Older</span>
              <span style="display:block; font-family:var(--font-display); font-weight:700; font-size:18px; color:var(--hi); margin-top:4px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">{nb.older.title}</span>
            </span>
          </a>
        ) : <span></span>}
        {nb.newer ? (
          <a href={`/${nb.newer.slug}/`} class="pn-card" style="display:flex; align-items:center; gap:14px; background:#1b232f; border:1px solid var(--border); border-radius:8px; padding:16px 18px; text-decoration:none; justify-content:flex-end; text-align:right; transition:border-color .15s;">
            <span style="min-width:0;">
              <span style="display:block; font:700 10px/1 var(--font-mono); color:var(--faint); letter-spacing:.12em; text-transform:uppercase;">Newer</span>
              <span style="display:block; font-family:var(--font-display); font-weight:700; font-size:18px; color:var(--hi); margin-top:4px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">{nb.newer.title}</span>
            </span>
            <span style="width:34px; height:34px; flex:0 0 34px; border-radius:50%; border:1px solid var(--border-strong); display:flex; align-items:center; justify-content:center; color:var(--chip-text); font-size:13px;">→</span>
          </a>
        ) : <span></span>}
      </div>
    )}
  </div>

  <!-- license footer -->
  <div style="max-width:920px; margin:0 auto 40px; padding:0 var(--pad); font:400 12px/1.6 var(--font-mono); color:var(--faint); text-align:center;">
    Everything here — audio included — is <a href="https://creativecommons.org/licenses/by-sa/4.0/" target="_blank" rel="noopener" style="color:var(--accent-light); text-decoration:none;">CC BY-SA 4.0</a>. Recorded by Travis Briggs.
  </div>

  <script>
    import '../scripts/wire-play.ts';
  </script>
</Base>

<style>
  .nav-link:hover { color: var(--text) !important; }
  .meta-chip:hover { background: var(--accent) !important; color: #fff !important; }
  .dl-btn:hover { background: var(--accent-deep); }
  .copy-btn:hover { border-color: var(--accent-light); color: var(--text); }
  .pn-card:hover { border-color: var(--accent) !important; }
  .note-body { font-size: 17px; line-height: 1.7; color: var(--chip-text); max-width: 62ch; }
  .note-body :global(p) { margin: 0 0 1em; }
  .note-body :global(a) { color: var(--accent-light); }
</style>
