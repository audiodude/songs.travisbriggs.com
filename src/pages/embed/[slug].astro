---
import { existsSync } from 'node:fs';
import { loadVisibleSongs } from '../../lib/songs';
import { fmtLongDate } from '../../lib/format';

// Iframe target for the `twitter:player` card on song pages (Mastodon et al.).
// Deliberately not built on Base: no nav, no global player island, no
// ClientRouter, no analytics — just a title and a native audio element that
// fits the advertised 400x150 player size. System fonts only, so the iframe
// loads with zero extra requests besides the audio itself.
//
// Embedding hosts (Mastodon instances) aren't known in advance, so this page
// must stay framable from any origin: no X-Frame-Options and no
// frame-ancestors CSP may ever be added to /embed/* .
export async function getStaticPaths() {
  const songs = await loadVisibleSongs();
  return songs.map((song) => ({ params: { slug: song.slug }, props: { song } }));
}

const { song } = Astro.props;
const trackUrl = new URL(`/${song.slug}/`, Astro.site).href;
const coverRel = existsSync(`public/covers/${song.slug}.jpg`) ? `/covers/${song.slug}.jpg` : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <link rel="canonical" href={trackUrl} />
    <title>{song.title} — Travis Briggs</title>
    <style>
      * { box-sizing: border-box; }
      html, body { margin: 0; height: 100%; }
      body {
        background: #1f2937;
        color: #fff;
        font-family: system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
      }
      .wrap {
        height: 100%;
        display: grid;
        grid-template-columns: auto 1fr;
        grid-template-rows: auto auto;
        align-content: center;
        column-gap: 14px;
        row-gap: 10px;
        padding: 14px 16px;
      }
      .cover {
        grid-row: 1 / 3;
        width: 92px;
        height: 92px;
        border-radius: 8px;
        object-fit: cover;
        background: #374151;
        display: block;
      }
      .no-cover { grid-column: 1 / -1; }
      .meta { min-width: 0; align-self: end; }
      audio { align-self: start; }
      .title {
        display: block;
        color: #fff;
        font-weight: 700;
        font-size: 16px;
        line-height: 1.2;
        text-decoration: none;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .title:hover { color: #60a5fa; }
      .by {
        margin-top: 3px;
        font-size: 12px;
        color: #9ca3af;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      audio { width: 100%; height: 40px; }
    </style>
  </head>
  <body>
    <div class="wrap">
      {coverRel && <img class="cover" src={coverRel} alt={`${song.title} cover`} width="92" height="92" />}
      <div class={`meta${coverRel ? '' : ' no-cover'}`}>
        <a class="title" href={trackUrl} target="_blank" rel="noopener">{song.title}</a>
        <div class="by">Travis Briggs · {fmtLongDate(song.date)}</div>
      </div>
      <audio class={coverRel ? '' : 'no-cover'} controls preload="metadata" src={song.src}></audio>
    </div>
  </body>
</html>
